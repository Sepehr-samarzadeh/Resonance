rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: authenticated users can read any profile,
    // but only write their own document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Imported playlists subcollection: same rules as the parent user document.
      match /importedPlaylists/{playlistId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    // Listening history: users can read/write their own sessions.
    match /listeningHistory/{userId}/sessions/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Matches: authenticated users can read matches they're part of,
    // and create new matches.
    match /matches/{matchId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.userIds;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.userIds;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.userIds;
      // Messages subcollection: participants can read/write messages.
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
      }
    }
  }
}
